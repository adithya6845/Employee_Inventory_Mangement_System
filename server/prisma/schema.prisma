generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  role      String    // admin, it_support, user
  employee  Employee?
  createdAt DateTime  @default(now())
}

model Department {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique
  employees Employee[]
  assets    Asset[]
  createdAt DateTime   @default(now())
}

model Employee {
  id           String    @id @default(cuid())
  employeeId   String    @unique
  firstName    String
  lastName     String
  email        String    @unique
  role         String
  department   Department @relation(fields: [departmentId], references: [id])
  departmentId String
  status       String    @default("active")
  user         User?     @relation(fields: [userId], references: [id])
  userId       String?   @unique

  allocations   Allocation[]
  returns       ReturnEvent[]
  damageReports DamageReport[]
  requests      Request[]

  createdAt    DateTime  @default(now())
}

model Asset {
  id           String    @id @default(cuid())
  assetId      String    @unique // E.g., AST-001
  name         String
  category     String    // Hardware, Furniture, Vehicle, etc.
  department   Department @relation(fields: [departmentId], references: [id])
  departmentId String
  manufacturer String?
  model        String?
  serialNumber String?
  purchaseDate DateTime?
  purchaseCost Int?
  
  // The status is derived from events, but we cache the latest state here for easy querying
  // States: In Stock, Allocated, Damaged, Retired
  status       String    @default("In Stock") 
  location     String?

  allocations   Allocation[]
  returns       ReturnEvent[]
  damageReports DamageReport[]
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ----------------------------------------
// EVENT SOURCING MODELS
// ----------------------------------------

model Allocation {
  id                 String    @id @default(cuid())
  asset              Asset     @relation(fields: [assetId], references: [id])
  assetId            String
  employee           Employee  @relation(fields: [employeeId], references: [id])
  employeeId         String
  allocatedAt        DateTime  @default(now())
  expectedReturnDate DateTime?
  actualReturnDate   DateTime?
  status             String    @default("Active") // Active, Returned
  notes              String?
}

model ReturnEvent {
  id          String   @id @default(cuid())
  asset       Asset    @relation(fields: [assetId], references: [id])
  assetId     String
  employee    Employee @relation(fields: [employeeId], references: [id])
  employeeId  String
  returnedAt  DateTime @default(now())
  condition   String   // Good, Damaged, Needs Repair
  notes       String?
}

model DamageReport {
  id          String   @id @default(cuid())
  asset       Asset    @relation(fields: [assetId], references: [id])
  assetId     String
  reportedBy  Employee @relation(fields: [reportedById], references: [id])
  reportedById String
  reportedAt  DateTime @default(now())
  severity    String   // Low, Medium, High, Critical
  description String
  imageUrl    String?
  status      String   @default("Open") // Open, In Repair, Resolved
}

// ----------------------------------------
// OTHER MODELS
// ----------------------------------------

model Request {
  id           String   @id @default(cuid())
  type         String   // Asset
  description  String
  status       String   @default("pending") // pending, approved, rejected
  employee     Employee @relation(fields: [employeeId], references: [id])
  employeeId   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AiQueryHistory {
  id        String   @id @default(cuid())
  query     String
  sql       String?
  timestamp DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  type      String
  timestamp DateTime @default(now())
}

